# Ignore everything in the root by default
/*

# Allow specific files/folders in the root
!/versiones/
!/build_all.ps1
!/README.md
!/.gitignore

# Allow all contents inside the allowed directories
!/versiones/**

# Multimedia centralized in https://github.com/jioryII/Ji-Assets
# (local multimedia/ folder is gitignored and not tracked)


# Ignore standard Java and Gradle build files within the allowed folders
.gradle/
build/
bin/
out/
.idea/
*.iml
.vscode/
run/
logs/
*.log
